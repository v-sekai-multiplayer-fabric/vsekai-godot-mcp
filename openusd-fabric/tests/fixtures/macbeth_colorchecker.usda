#usda 1.0
(
    """
    X-Rite / Macbeth ColorChecker reference fixture (24 patches, 4 rows
    by 6 columns). sRGB-D65 values from Wikipedia "ColorChecker"
    (Manufacturer's sRGB color values).

    Each patch carries three forms of colour so every consumer picks
    one up:
      * `primvars:displayColor` — vertex-colour fallback for Solid
        viewport shading and renderers that bypass material bindings.
      * `outputs:surface` -> UsdPreviewSurface — hdStorm's native path.
      * `outputs:mtlx:surface` -> MaterialX `ND_standard_surface_surfaceshader`
        — Blender 4.4+ MaterialX importer, hdMtlx renderer delegates.

    Regenerated by `python scripts/generate_macbeth_fixture.py`. Do
    not hand-edit — colour values and per-Material boilerplate live in
    that script.

    Copyright 2026 The openusd-fabric authors.
    SPDX-License-Identifier: MIT
    """
    defaultPrim = "Chart"
    upAxis = "Y"
    metersPerUnit = 1.0
)

def Xform "Chart"
{
