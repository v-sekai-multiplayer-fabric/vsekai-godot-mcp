--
-- VSekaiSpringBoneAPI field-domain constraints (CHI-251).
--
-- Worked example of the Lean -> Python validator emission pattern:
-- specifies the legal domains as total predicates over the input space,
-- then `emit_artifacts` writes a Python validator imported by the
-- Blender hook (and a parallel C++ predicate idtx-flow links into).
--
-- The native_decide proof at the bottom pins the emitted validator's
-- bytes so a hand-edit of the generated Python file fails the build.

namespace Fabric.Schema.SpringBoneRanges

/-- All scalar springbone fields encoded as their authored value. -/
structure Fields where
  stiffness    : Float  -- expected in [0, 1]
  drag         : Float  -- expected in [0, 1]
  gravityPower : Float  -- expected >= 0
  hitRadius    : Float  -- expected > 0
  deriving Repr

/-- Range bound. -/
inductive Bound where
  | inclusive (v : String)  -- e.g. "0.0" — the operator emitted is <=
  | exclusive (v : String)  -- e.g. "0.0" — emit <
  | unbounded

/-- A single field constraint: lo <= x <= hi (or one side unbounded). -/
structure RangeSpec where
  pyField  : String         -- "stiffness"
  cField   : String         -- "stiffness"
  lo       : Bound
  hi       : Bound

/-- The 4 springbone field constraints. Single source of truth for
    both validators and the predicate below. -/
def ranges : List RangeSpec :=
  [ { pyField := "stiffness",     cField := "stiffness"
    , lo := .inclusive "0.0", hi := .inclusive "1.0" }
  , { pyField := "drag",          cField := "drag"
    , lo := .inclusive "0.0", hi := .inclusive "1.0" }
  , { pyField := "gravity_power", cField := "gravity_power"
    , lo := .inclusive "0.0", hi := .unbounded }
  , { pyField := "hit_radius",    cField := "hit_radius"
    , lo := .exclusive "0.0", hi := .unbounded }
  ]

/-- Is `f` a valid springbone payload? Total over Fields.
    Kept hand-coded to drive the spec proofs; the generators below
    derive equivalent code from `ranges`. -/
def isValid (f : Fields) : Bool :=
  0.0 <= f.stiffness    && f.stiffness    <= 1.0 &&
  0.0 <= f.drag         && f.drag         <= 1.0 &&
  0.0 <= f.gravityPower &&
  0.0 <  f.hitRadius

/-- Python validator: emit `lo <= x <= hi` style chained comparisons. -/
def genPythonCondition (r : RangeSpec) : String :=
  match r.lo, r.hi with
  | .inclusive lo, .inclusive hi =>
      lo ++ " <= " ++ r.pyField ++ " <= " ++ hi
  | .exclusive lo, .inclusive hi =>
      lo ++ " <  " ++ r.pyField ++ " <= " ++ hi
  | .inclusive lo, .exclusive hi =>
      lo ++ " <= " ++ r.pyField ++ " <  " ++ hi
  | .exclusive lo, .exclusive hi =>
      lo ++ " <  " ++ r.pyField ++ " <  " ++ hi
  | .inclusive lo, .unbounded =>
      lo ++ " <= " ++ r.pyField
  | .exclusive lo, .unbounded =>
      lo ++ " <  " ++ r.pyField
  | .unbounded, .inclusive hi =>
      r.pyField ++ " <= " ++ hi
  | .unbounded, .exclusive hi =>
      r.pyField ++ " <  " ++ hi
  | .unbounded, .unbounded => "True"

/-- C++ validator condition. `<=` becomes `<=`; `<` becomes `<`. Uses
    `f` suffix on float literals to avoid double-conversion warnings. -/
def genCppCondition (r : RangeSpec) : String :=
  let addF (b : Bound) : Bound :=
    match b with
    | .inclusive v => .inclusive (v ++ "f")
    | .exclusive v => .exclusive (v ++ "f")
    | .unbounded   => .unbounded
  let r' : RangeSpec := { pyField := r.cField, cField := r.cField
                        , lo := addF r.lo, hi := addF r.hi }
  match r'.lo, r'.hi with
  | .inclusive lo, .inclusive hi =>
      lo ++ " <= " ++ r'.cField ++ " && " ++ r'.cField ++ " <= " ++ hi
  | .exclusive lo, .inclusive hi =>
      lo ++ " <  " ++ r'.cField ++ " && " ++ r'.cField ++ " <= " ++ hi
  | .inclusive lo, .exclusive hi =>
      lo ++ " <= " ++ r'.cField ++ " && " ++ r'.cField ++ " <  " ++ hi
  | .exclusive lo, .exclusive hi =>
      lo ++ " <  " ++ r'.cField ++ " && " ++ r'.cField ++ " <  " ++ hi
  | .inclusive lo, .unbounded =>
      lo ++ " <= " ++ r'.cField
  | .exclusive lo, .unbounded =>
      lo ++ " <  " ++ r'.cField
  | .unbounded, .inclusive hi =>
      r'.cField ++ " <= " ++ hi
  | .unbounded, .exclusive hi =>
      r'.cField ++ " <  " ++ hi
  | .unbounded, .unbounded => "true"

/-- Generator: derive Python validator source from `ranges`. -/
def genPythonValidator : String :=
  let header := "# AUTO-GENERATED by lean/EmitArtifacts.lean. DO NOT EDIT.
# Specification: lean/Fabric/Schema/SpringBoneRanges.lean

def is_valid_spring_bone(stiffness, drag, gravity_power, hit_radius):
    return (
"
  let conds := String.intercalate " and\n" <|
    ranges.map fun r => "        " ++ genPythonCondition r
  let footer := "\n    )
"
  header ++ conds ++ footer

/-- Generator: derive C++ validator header from `ranges`. -/
def genCppValidator : String :=
  let header := "// AUTO-GENERATED by lean/EmitArtifacts.lean. DO NOT EDIT.
// Specification: lean/Fabric/Schema/SpringBoneRanges.lean
#pragma once

namespace v_sekai {

inline bool is_valid_spring_bone(float stiffness, float drag,
                                 float gravity_power, float hit_radius) {
    return "
  let conds := String.intercalate "\n        && " (ranges.map genCppCondition)
  let footer := ";
}

}  // namespace v_sekai
"
  header ++ conds ++ footer

/-- Canonical Python source the emit exe writes for the Blender hook. -/
def pythonValidatorSource : String := genPythonValidator

/-- C++ inline header for the idtx-flow consumer. -/
def cppValidatorSource : String := genCppValidator

/-- Literal copy of the shipping Python validator. -/
def committedPythonBytes : String :=
"# AUTO-GENERATED by lean/EmitArtifacts.lean. DO NOT EDIT.
# Specification: lean/Fabric/Schema/SpringBoneRanges.lean

def is_valid_spring_bone(stiffness, drag, gravity_power, hit_radius):
    return (
        0.0 <= stiffness <= 1.0 and
        0.0 <= drag <= 1.0 and
        0.0 <= gravity_power and
        0.0 <  hit_radius
    )
"

/-- Literal copy of the shipping C++ validator header. -/
def committedCppBytes : String :=
"// AUTO-GENERATED by lean/EmitArtifacts.lean. DO NOT EDIT.
// Specification: lean/Fabric/Schema/SpringBoneRanges.lean
#pragma once

namespace v_sekai {

inline bool is_valid_spring_bone(float stiffness, float drag,
                                 float gravity_power, float hit_radius) {
    return 0.0f <= stiffness && stiffness <= 1.0f
        && 0.0f <= drag && drag <= 1.0f
        && 0.0f <= gravity_power
        && 0.0f <  hit_radius;
}

}  // namespace v_sekai
"

/-- CHI-254 byte-pins: shipping bytes must equal spec-derived bytes. -/
theorem committedPythonBytes_matches_genPython :
    committedPythonBytes = genPythonValidator := by native_decide

theorem committedCppBytes_matches_genCpp :
    committedCppBytes = genCppValidator := by native_decide

end Fabric.Schema.SpringBoneRanges
