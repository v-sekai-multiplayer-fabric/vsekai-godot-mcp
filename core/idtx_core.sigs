int32_t idtx_chunklist_count(const idtx_chunklist_t* cl);
int32_t idtx_chunklist_get(const idtx_chunklist_t* cl, int32_t index, uint64_t* out_offset, uint64_t* out_size, uint8_t out_id[IDTX_CHUNKER_CHUNK_ID_BYTES]);
void idtx_chunklist_destroy(idtx_chunklist_t* cl);
int32_t idtx_chunker_parse_caibx(const uint8_t* data, size_t len, idtx_caibx_t** out_index);
int32_t idtx_caibx_chunk_count(const idtx_caibx_t* idx);
int32_t idtx_caibx_get_chunk(const idtx_caibx_t* idx, int32_t index, uint64_t* out_offset, uint64_t* out_size, uint8_t out_id[IDTX_CHUNKER_CHUNK_ID_BYTES]);
void idtx_caibx_destroy(idtx_caibx_t* idx);
int32_t idtx_chunker_emit_caibx(const idtx_chunklist_t* cl, size_t chunk_size_min, size_t chunk_size_avg, size_t chunk_size_max, idtx_buffer_t** out_caibx);
int32_t idtx_chunker_decompress_and_verify(const uint8_t* cacnk_zstd, size_t cacnk_len, const uint8_t expected_id[IDTX_CHUNKER_CHUNK_ID_BYTES], idtx_buffer_t** out_plain);
int32_t idtx_chunker_compress(const uint8_t* plain, size_t plain_len, idtx_buffer_t** out_cacnk);

